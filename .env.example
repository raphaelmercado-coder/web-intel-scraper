# Google Sheets — OAuth 2.0 credentials
# 1. Create OAuth client at https://console.cloud.google.com/apis/credentials
#    (Application type: Desktop app — or Web app with redirect URI below)
# 2. Run a one-time consent flow to obtain a refresh token (scope:
#    https://www.googleapis.com/auth/spreadsheets) and paste it below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=http://localhost
GOOGLE_SHEETS_SPREADSHEET_ID=

# Google Drive — folder ID to upload generated .docx reports into
# Refresh token MUST also include scope: https://www.googleapis.com/auth/drive.file
GOOGLE_DRIVE_FOLDER_ID=

# Webhook server (n8n → company-report task)
WEBHOOK_SECRET=
WEBHOOK_PORT=3000

# Trust Center Collector
N8N_TRUST_WEBHOOK_URL=https://n8n.example.com/webhook/trust-center-findings
N8N_TRUST_WEBHOOK_SECRET=
