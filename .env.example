# Trigger.dev v4
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Firecrawl — https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# Google Sheets — Service Account
# 1. Create service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Download JSON key and save to project root with this filename
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=service-account-key.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# Google Drive — folder ID to upload generated .docx reports into
GOOGLE_DRIVE_FOLDER_ID=

# Webhook server (n8n → company-report task)
WEBHOOK_SECRET=
WEBHOOK_PORT=3000

# Trust Center Collector
N8N_TRUST_WEBHOOK_URL=https://n8n.example.com/webhook/trust-center-findings
N8N_TRUST_WEBHOOK_SECRET=
TRUST_ACCOUNTS_RANGE=Accounts!A2:L
TRUST_OPENAI_MODEL=gpt-4o-mini
