{
  "name": "Company Report — Trigger.dev Webhook",
  "nodes": [
    {
      "parameters": {
        "formTitle": "Generate Company Report",
        "formDescription": "Submit a company to generate a strategic report (.docx in Drive).",
        "formFields": {
          "values": [
            { "fieldLabel": "Company Name", "fieldType": "text", "requiredField": true },
            { "fieldLabel": "Industry",     "fieldType": "text", "requiredField": true },
            { "fieldLabel": "Goal",         "fieldType": "textarea", "requiredField": true },
            { "fieldLabel": "Challenge",    "fieldType": "textarea", "requiredField": true }
          ]
        },
        "options": {}
      },
      "id": "form-trigger",
      "name": "Company Form",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2.2,
      "position": [240, 300],
      "webhookId": "company-report-form"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://phase3-webhook-production.up.railway.app/webhooks/company-report",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-webhook-secret", "value": "={{$env.WEBHOOK_SECRET}}" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={\n  \"companyName\": {{ JSON.stringify($json[\"Company Name\"]) }},\n  \"industry\":    {{ JSON.stringify($json[\"Industry\"]) }},\n  \"goal\":        {{ JSON.stringify($json[\"Goal\"]) }},\n  \"challenge\":   {{ JSON.stringify($json[\"Challenge\"]) }}\n}",
        "options": {
          "response": { "response": { "fullResponse": false } }
        }
      },
      "id": "http-request",
      "name": "POST to Trigger.dev Webhook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300]
    }
  ],
  "connections": {
    "Company Form": {
      "main": [
        [{ "node": "POST to Trigger.dev Webhook", "type": "main", "index": 0 }]
      ]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1" }
}
